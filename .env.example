# Afarinsene — Environment variable examples
# Copy this file to .env and fill in your values.
# .env is git-ignored.

# Path to your image dataset root folder
DATA_DIR=/path/to/DATASET

# (Optional) Force CPU even if a GPU is present
# CUDA_VISIBLE_DEVICES=-1

# (Optional) TensorFlow log level (0=all, 1=no INFO, 2=no WARNING, 3=errors only)
# TF_CPP_MIN_LOG_LEVEL=2
